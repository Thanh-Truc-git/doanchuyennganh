@model dynamic
@using WebPhanTich.Models

@{
    bool isAdmin = ViewBag.IsAdmin ?? false;

    var iconMap = new Dictionary<string, object>
    {
        { "Động vật", new { IconClass = "bi bi-bug", Color = "#1E90FF" } },
        { "Gia đình", new { IconClass = "bi bi-people", Color = "#32CD32" } },
        { "Màu sắc", new { IconClass = "bi bi-palette", Color = "#FF8C00" } },
        { "Thức ăn", new { IconClass = "bi bi-cup-hot", Color = "#FF4500" } },
        { "Thức uống", new { IconClass = "bi bi-cup", Color = "#00BFFF" } },
        { "Trường học", new { IconClass = "bi bi-journal", Color = "#228B22" } },
        { "Nghề nghiệp", new { IconClass = "bi bi-briefcase", Color = "#8B0000" } },
        { "Cơ thể", new { IconClass = "bi bi-person", Color = "#FF69B4" } },
        { "Thời tiết", new { IconClass = "bi bi-sun", Color = "#FFD700" } },
        { "Cảm xúc", new { IconClass = "bi bi-emoji-smile", Color = "#FF6347" } }
    };
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<style>
    .category-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        max-width: 180px;
        height: 140px;
        text-align: center;
        text-decoration: none;
        border-radius: 20px;
        transition: transform 0.2s, box-shadow 0.2s;
        font-weight: bold;
        margin: 0 auto;
    }

        .category-btn i {
            font-size: 3rem;
            margin-bottom: 10px;
        }

        .category-btn span {
            font-size: 1rem;
            font-weight: 600;
        }

        .category-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

    .audio-controls button {
        margin-right: 5px;
        margin-top: 5px;
    }

    .feedback {
        margin-top: 5px;
        font-weight: bold;
        color: #d9534f;
    }

    .phoneme-card {
        margin-top: 8px;
        padding: 8px;
        border-radius: 6px;
    }
</style>

<div class="container mt-5">
    @if (Model is IEnumerable<Category> categories)
    {
        <div class="row justify-content-center">
            @foreach (var cat in categories)
            {
                var iconInfo = iconMap.ContainsKey(cat.Name) ? iconMap[cat.Name] : new { IconClass = "bi bi-book", Color = "#333" };
                <div class="col-12 col-sm-6 col-md-4 mb-4 text-center">
                    <a class="category-btn d-inline-block" href="@Url.Action("Index", "Vocabulary", new { categoryId = cat.Id })" style="color:@iconInfo.GetType().GetProperty("Color").GetValue(iconInfo, null)">
                        <i class="@iconInfo.GetType().GetProperty("IconClass").GetValue(iconInfo, null)"></i>
                        <span>@cat.Name</span>
                    </a>
                </div>
            }
        </div>
    }
    else if (Model is IEnumerable<Vocabulary> vocabularies)
    {
        <h2 class="text-center mb-3">@ViewBag.CategoryName</h2>

        @if (isAdmin)
        {
            <a class="btn btn-success mb-3" href="@Url.Action("Create", "Vocabulary")">Thêm từ vựng</a>
        }

        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var item in vocabularies)
            {
                <div class="col">
                    <div class="card p-3 h-100" data-kanji="@item.Word">
                        <h5>@item.Word (@item.Hiragana / @item.Katakana)</h5>
                        <p><strong>Ý nghĩa:</strong> @item.Meaning</p>

                        @if (!string.IsNullOrEmpty(item.AudioPath))
                        {
                            <p>Nghe mẫu:</p>
                            <audio controls>
                                <source src="@Url.Content(item.AudioPath)" type="audio/mp3" />
                            </audio>
                        }

                        <hr />
                        <h6>Ghi âm luyện tập:</h6>
                        <div class="audio-controls">
                            <button class="btn btn-primary startBtn">Bắt đầu</button>
                            <button class="btn btn-danger stopBtn" disabled>Dừng</button>
                            <button class="btn btn-success sendBtn" disabled>Gửi</button>
                        </div>
                        <audio class="audioPlayback mt-2" controls></audio>
                        <div class="feedback"></div>

                        @if (isAdmin)
                        {
                            <hr />
                            <div>
                                <a class="btn btn-primary btn-sm" href="@Url.Action("Edit", "Vocabulary", new { id = item.Id })">Sửa</a>
                                <a class="btn btn-danger btn-sm" href="@Url.Action("Delete", "Vocabulary", new { id = item.Id })">Xóa</a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <a class="btn btn-secondary mt-4" href="@Url.Action("Index", "Vocabulary")">Quay lại danh sách chủ đề</a>
    }
</div>

<script>
    document.querySelectorAll('.card').forEach(card => {
        const startBtn = card.querySelector('.startBtn');
        const stopBtn = card.querySelector('.stopBtn');
        const sendBtn = card.querySelector('.sendBtn');
        const audioPlayback = card.querySelector('.audioPlayback');
        const feedbackDiv = card.querySelector('.feedback');
        const kanji = card.getAttribute('data-kanji');

        let mediaRecorder;
        let audioChunks = [];
        let audioBlob;

        startBtn.addEventListener('click', async () => {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream);
                audioChunks = [];
                mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
                mediaRecorder.onstop = () => {
                    audioBlob = new Blob(audioChunks, { type: mediaRecorder.mimeType });
                    audioPlayback.src = URL.createObjectURL(audioBlob);
                    sendBtn.disabled = false;
                };
                mediaRecorder.start();
                startBtn.disabled = true;
                stopBtn.disabled = false;
                feedbackDiv.textContent = "🎙️ Đang ghi...";
            } catch (err) {
                console.error(err);
                feedbackDiv.textContent = "⚠️ Không thể truy cập micro.";
            }
        });

        stopBtn.addEventListener('click', () => {
            if(mediaRecorder) mediaRecorder.stop();
            startBtn.disabled = false;
            stopBtn.disabled = true;
            feedbackDiv.textContent = "✅ Đã ghi xong.";
        });

        sendBtn.addEventListener('click', async () => {
            feedbackDiv.innerHTML = "<span style='color:#555;'>⏳ Đang gửi file để phân tích...</span>";
            const formData = new FormData();
            formData.append('file', audioBlob, 'recording.webm');
            formData.append('word', kanji);

            try {
                const response = await fetch('http://127.0.0.1:5001/analyze', { method:'POST', body: formData });
                if(response.ok){
                    const data = await response.json();
                    // Hiển thị tổng kết
                    let html = `<div class="mt-3 p-3 border rounded" style="background:#fffbe7;">
                                    <div style="font-size:1.1em; font-weight:bold;">
                                        🔤 Từ: ${data.word} (${data.romaji})<br/>
                                        📊 Tổng quan: ${data.summary}
                                    </div>
                                    <div style="margin-top:8px; font-weight:bold;">🔤 Phân tích từng âm:</div>`;
                    if(data.analysis && data.analysis.length > 0){
                        data.analysis.forEach(p => {
                            let statusColor = "#28a745", icon="✅";
                            if(p.status==="weak"){ statusColor="#ffc107"; icon="😐"; }
                            else if(p.status==="wrong" || p.status==="error"){ statusColor="#dc3545"; icon="❌"; }

                            html += `<div class="phoneme-card" style="border-left:5px solid ${statusColor}; background:#f9f9f9;">
                                        <b>${icon} ${p.phoneme || "N/A"}</b> — ${p.score || "N/A"} điểm
                                        ${p.issues && p.issues.length>0 ? `<ul style="margin:5px 0 0 20px; color:#d9534f;">${p.issues.map(i=>`<li>${i}</li>`).join("")}</ul>` : ""}
                                        ${p.tip ? `<div style="color:#006400; margin-top:4px;">👉 Gợi ý: ${p.tip}</div>` : ""}
                                     </div>`;
                        });
                    } else {
                        html += "<div>Không có dữ liệu phân tích.</div>";
                    }
                    html += "</div>";
                    feedbackDiv.innerHTML = html;
                    sendBtn.disabled = true;
                } else {
                    const errText = await response.text();
                    feedbackDiv.innerHTML = `<span style="color:#dc3545;">❌ Lỗi API: ${errText}</span>`;
                }
            } catch(err){
                console.error(err);
                feedbackDiv.innerHTML = "<span style='color:#dc3545;'>❌ Không thể kết nối đến API.</span>";
            }
        });
    });
</script>
