@model WebPhanTich.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục";
}

<h2 class="text-center mb-3">➕ Thêm danh mục mới</h2>

<form asp-action="Create" method="post" class="shadow-sm p-4 rounded bg-light">
    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label fw-bold">Tên danh mục</label>
        <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục..." />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn về danh mục..."></textarea>
    </div>

    <div class="text-center">
        <button type="submit" class="btn btn-primary">💾 Lưu</button>
        <a asp-action="Index" class="btn btn-secondary">↩️ Quay lại</a>
    </div>
</form>
