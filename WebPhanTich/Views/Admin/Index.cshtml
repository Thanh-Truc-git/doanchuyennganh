@model IEnumerable<WebPhanTich.Models.PronunciationSample>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Danh sách từ mẫu</h2>
<a class="btn btn-success mb-2" asp-action="Create">Thêm mới</a>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Từ</th>
            <th>IPA</th>
            <th>Audio</th>
            <th>Mô tả</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Word</td>
                <td>@item.IPA</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.AudioPath))
                    {
                        <audio controls>
                            <source src="@item.AudioPath" type="audio/mpeg" />
                        </audio>
                    }
                </td>
                <td>@item.Description</td>
                <td>
                    <a class="btn btn-primary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
