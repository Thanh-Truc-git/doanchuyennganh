@model IEnumerable<WebPhanTich.Models.PronunciationSample>

@{
    ViewData["Title"] = "Danh sách mẫu phát âm";
}

<h2 class="mb-3">@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Thêm mẫu mới</a>
</p>

<table class="table table-bordered table-striped">
    <thead class="table-warning">
        <tr>
            <th>Từ</th>
            <th>IPA</th>
            <th>Âm thanh</th>
            <th>Mô tả</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Word</td>
                <td>@item.IPA</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.AudioPath))
                    {
                        <audio controls style="height:30px;">
                            <source src="@item.AudioPath" type="audio/mpeg" />
                        </audio>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file</span>
                    }
                </td>
                <td>@item.Description</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">✏️</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">🗑️</a>
                </td>
            </tr>
        }
    </tbody>
</table>
